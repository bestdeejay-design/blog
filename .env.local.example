# =====================================================
# ENVIRONMENT VARIABLES CONFIGURATION
# =====================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git (it's in .gitignore)
# =====================================================

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
# Get these from your Supabase project:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Settings → API
# =====================================================

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (public, can be exposed to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (SECRET - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# JWT CONFIGURATION
# =====================================================
# Generate a strong secret key (min 32 characters)
# You can use: openssl rand -base64 32
# =====================================================

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# JWT expiration time (default: 7 days)
JWT_EXPIRATION=7d

# =====================================================
# APPLICATION SETTINGS
# =====================================================

# Application URL (production)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# API URL for widgets
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# =====================================================
# UPLOAD SETTINGS (Optional)
# =====================================================

# Supabase Storage bucket for media uploads
NEXT_PUBLIC_STORAGE_BUCKET=media

# Max file size in MB (default: 5MB)
MAX_FILE_SIZE=5

# Allowed image types
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# =====================================================
# SECURITY SETTINGS (Optional)
# =====================================================

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =====================================================
# DEVELOPMENT SETTINGS (Optional)
# =====================================================

# Enable debug logging
DEBUG=false

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# =====================================================
# QUICK SETUP GUIDE
# =====================================================
# 1. Copy this file:
#    cp .env.local.example .env.local
#
# 2. Fill in your Supabase credentials:
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - SUPABASE_SERVICE_ROLE_KEY
#
# 3. Generate JWT secret:
#    openssl rand -base64 32
#
# 4. Save and run:
#    npm run dev
#
# 5. Visit http://localhost:3000/login
# =====================================================
